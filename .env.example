SUPABASE_URL=
# Base project URL only, e.g. https://xxxxx.supabase.co
# Do NOT append /rest/v1/ or any other path, the code builds full paths from this.
SUPABASE_PUBLISHABLE_KEY=
SUPABASE_SECRET_KEY=
SUPABASE_DB_PASSWORD=

HF_TOKEN=
# Hugging Face token, must have the "Inference Providers" permission explicitly
# enabled. Fine-grained tokens default to NOT having it, causing 403s.

GROQ_API_KEY=
# Used by both the Synthesizer (backend/app/agents/synthesizer.py) and the
# query-text injection guard (backend/app/services/injection_guard.py).

GROQ_REPORT_MODEL=
GROQ_REPORT_MAP_MODEL=
# Optional (Sprint 4.6a, docs/ADR-022.md). Report generation's model split:
# the final write defaults to openai/gpt-oss-120b, the map/classify passes to
# openai/gpt-oss-20b. Set these only to override — e.g. when Groq deprecates
# a model — no code change needed.

LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_BASE_URL=https://cloud.langfuse.com
# Optional. If these are absent, Langfuse observability is cleanly disabled
# (one startup log line); research is never affected either way. Base URL must
# match the region your Langfuse Cloud project actually runs in — check
# Project Settings for the exact value. Known regions: EU (default)
# cloud.langfuse.com, US us.cloud.langfuse.com, Japan jp.cloud.langfuse.com.
# NOTE: the SDK v4 env var is LANGFUSE_BASE_URL, not LANGFUSE_HOST (renamed
# upstream). If you set LANGFUSE_HOST on Render from an earlier version of
# this file, rename it to LANGFUSE_BASE_URL — same value, new key name.

TAVILY_API_KEY=
# Sprint 3b (Web Scout). Optional — if unset, the Orchestrator can still set
# use_web=True but web_scout.py degrades cleanly to doc-only research with a
# banner (see docs/ADR-017.md). Also reused by Sprint 4.6a's report-template
# lookup, with the same degrade path. Get a key at tavily.com.

GEMINI_API_KEY=
GEMINI_MODEL=
# Sprint 4.5 (public project-Q&A chatbot, docs/ADR-021.md). Optional — if the
# key is unset the chatbot degrades to a graceful "resting" reply, nothing
# else is affected. Create the key in a SEPARATE Google Cloud project (quota
# isolation). GEMINI_MODEL overrides the default (gemini-3.1-flash-lite).

CHAT_MAX_PER_IP=
CHAT_MAX_PER_DAY=
# Optional chatbot rate-limit overrides (defaults: 6/min per IP, 300/day
# global). See main.py's chat rate-limiting block.
