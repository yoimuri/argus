SUPABASE_URL=
# Base project URL only, e.g. https://xxxxx.supabase.co
# Do NOT append /rest/v1/ or any other path, the code builds full paths from this.
SUPABASE_PUBLISHABLE_KEY=
SUPABASE_SECRET_KEY=
SUPABASE_DB_PASSWORD=

HF_TOKEN=
# Hugging Face token, must have the "Inference Providers" permission explicitly
# enabled. Fine-grained tokens default to NOT having it, causing 403s.

GROQ_API_KEY=
# Used by both the Synthesizer (backend/app/agents/synthesizer.py) and the
# query-text injection guard (backend/app/services/injection_guard.py).

LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=https://cloud.langfuse.com
# Optional. If these are absent, Langfuse observability is cleanly disabled
# (one startup log line); research is never affected either way. Host must
# match the region your Langfuse Cloud project actually runs in (EU:
# cloud.langfuse.com, US: us.cloud.langfuse.com) — check Project Settings.
